# Copy to `configs/.env` (gitignored) for host-side tools:
#   cts_ml/scripts/load_csv_to_postgres.py, cts_ml/scripts/build_dataset.py (--env-file ..\configs\.env).
# First-time: copy this file to `configs/.env` and adjust POSTGRES_DSN if your Compose credentials differ.
# URL-encode reserved characters in the password (e.g. `@` -> `%40`).

POSTGRES_DSN=postgresql://cts_user:change_me_local_only@127.0.0.1:5432/ctsdb
