# Copy to phase4_api/.env (gitignored). Paths relative to cts_ml/ when you start uvicorn from cts_ml/.
#
# Rollout: shadow first (EA logs score / threshold / would_allow; no blocking).
# Filter: allow if score >= CTS_AI_THRESHOLD. Fail-safe when filter ON: timeout/error => skip trade.
# Shadow fail-safe: timeout/error => continue + log (EA Week 3).

CTS_PHASE3_MODEL=../exports/phase3_v1/model.joblib
# Optional override if manifest is not next to model.joblib:
# CTS_MANIFEST_PATH=../exports/phase3_v1/manifest.json

CTS_AI_THRESHOLD=0.65
CTS_API_HOST=127.0.0.1
CTS_API_PORT=8008
# Server-side scoring budget per POST /score (milliseconds); EA should use a higher WebRequest timeout.
CTS_SCORE_TIMEOUT_MS=200

# Phase 5 — per-bucket threshold / risk (restart uvicorn after YAML edits)
CTS_ADAPTIVE_CONFIG=../configs/adaptive_v1.yaml
